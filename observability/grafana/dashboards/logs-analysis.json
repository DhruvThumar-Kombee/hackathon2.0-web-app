  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Error Logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"hackathon-api\"} | json | level=\"error\" or level=\"ERROR\" or level=\"warning\" or level=\"WARNING\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "id": 2,
      "title": "Log severity breakdown",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({job=\"hackathon-api\"} | json [1h]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "type": "piechart"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "id": 3,
      "title": "Login Failures (Recent)",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"hackathon-api\"} | json | msg=~\".*login.*failed.*\" or msg=~\".*Authentication.*failed.*\" or status_code=401",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "id": 4,
      "title": "Validation Failures (Recent)",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"hackathon-api\"} | json | msg=~\".*validation.*failed.*\" or status_code=422",
          "refId": "A"
        }
      ],
      "type": "logs"
    }
  ],
