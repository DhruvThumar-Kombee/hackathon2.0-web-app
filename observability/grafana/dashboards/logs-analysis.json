{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Error & Warning Logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"backend\"} | json | level=~\"error|ERROR|warning|WARNING\"",
          "refId": "A"
        }
      ],
      "type": "logs",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showTime": true, "wrapLogMessage": false }
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 10 },
      "id": 2,
      "title": "Log Count by Severity",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({service=\"backend\"} | json [5m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "type": "piechart"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 10 },
      "id": 3,
      "title": "Login Failures",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"backend\"} | json | message=\"LOGIN_FAILED\"",
          "refId": "A"
        }
      ],
      "type": "logs",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true }
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 10 },
      "id": 4,
      "title": "Validation Failures (422)",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"backend\"} | json | status_code=\"422\" or message=~\".*VALIDATION.*FAILED.*\"",
          "refId": "A"
        }
      ],
      "type": "logs",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true }
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "id": 5,
      "title": "Filter Logs by Trace ID",
      "description": "Enter a trace_id value in the variable above to correlate logs to a specific trace",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"backend\"} | json | trace_id=~\"$trace_id\"",
          "refId": "A"
        }
      ],
      "type": "logs",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "wrapLogMessage": true }
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 25 },
      "id": 6,
      "title": "Log Volume Over Time (by level)",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({service=\"backend\"} | json [1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["hackathon"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": ".*", "value": ".*" },
        "description": "Paste a trace_id to filter logs for that specific request",
        "hide": 0,
        "label": "Trace ID",
        "name": "trace_id",
        "options": [{ "selected": true, "text": ".*", "value": ".*" }],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Logs Analysis",
  "uid": "logs-analysis",
  "version": 3
}
